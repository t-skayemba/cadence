# Cadence Environment Variables Template
# 1. Copy this file and rename it to '.env'
# 2. Add your own Groq API Key below

API_KEY=your_groq_api_key_here

# Optional: Port for local development (Default is 8080 to avoid Mac AirPlay issues)
PORT=8080

# Optional: Database URL (Default is sqlite:///cadence.db)
DATABASE_URL=sqlite:///cadence.db

# The model to use. 
# Use 'llama-3.3-70b-versatile' for high quality.
# Use 'llama-3.3-70b-specdec' if you hit rate limits.
GROQ_MODEL=llama-3.3-70b-specdec